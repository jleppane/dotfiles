#!/usr/bin/env bash

NORMAL=$(echo -en '\001\033[0m\002')
BLACK=$(echo -en '\001\033[00;30m\002')
BLUE=$(echo -en '\001\033[00;34m\002')
GREEN=$(echo -en '\001\033[00;32m\002')
CYAN=$(echo -en '\001\033[00;36m\002')
RED=$(echo -en '\001\033[00;31m\002')
PURPLE=$(echo -en '\001\033[00;35m\002')
BROWN=$(echo -en '\001\033[00;33m\002')
LIGHT_GRAY=$(echo -en '\001\033[00;37m\002')
DARK_GRAY=$(echo -en '\001\033[01;30m\002')
LIGHT_BLUE=$(echo -en '\001\033[01;34m\002')
LIGHT_GREEN=$(echo -en '\001\033[01;32m\002')
LIGHT_CYAN=$(echo -en '\001\033[01;36m\002')
LIGHT_RED=$(echo -en '\001\033[01;31m\002')
LIGHT_PURPLE=$(echo -en '\001\033[01;35m\002')
YELLOW=$(echo -en '\001\033[00;33m\002')
WHITE=$(echo -en '\001\033[01;37m\002')
